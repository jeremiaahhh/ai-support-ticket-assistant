# ──────────────────────────────────────────────────────────────────────────────
# AI Support Ticket Assistant — environment defaults
# Copy this file to `.env` and adjust as needed.
# ──────────────────────────────────────────────────────────────────────────────

# Backend
BACKEND_PORT=8000

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Postgres
POSTGRES_USER=support
POSTGRES_PASSWORD=support
POSTGRES_DB=support_ticket_assistant
POSTGRES_PORT=5432

# ── AI provider ───────────────────────────────────────────────────────────────
# When USE_MOCK_AI=true (or no key is set), the backend uses deterministic mock
# providers — perfect for local demos. Set USE_MOCK_AI=false and an API key to
# enable live model calls.
USE_MOCK_AI=true

# Choose one: "anthropic" or "openai"
AI_PROVIDER=anthropic

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
